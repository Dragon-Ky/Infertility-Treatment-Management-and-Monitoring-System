APP_NAME="Report Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8006

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql-report
DB_PORT=3306
DB_DATABASE=report_db
DB_USERNAME=root
DB_PASSWORD=secret

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Cache Configuration
CACHE_STORE=redis
CACHE_PREFIX=report_service_

# Redis Configuration
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreport@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Service URLs (Other Microservices)
AUTH_SERVICE_URL=http://auth-service:8000
CATALOG_SERVICE_URL=http://catalog-service:8000
APPOINTMENT_SERVICE_URL=http://appointment-service:8000
TREATMENT_SERVICE_URL=http://treatment-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000

# Apache NiFi Configuration
NIFI_BASE_URL=http://nifi:8443
NIFI_API_PATH=/nifi-api
NIFI_USERNAME=admin
NIFI_PASSWORD=admin

# Report Service Specific
REPORT_CACHE_TTL=900
DASHBOARD_CACHE_TTL=900
STATISTICS_CACHE_TTL=3600

VITE_APP_NAME="${APP_NAME}"

# Mã kết nối api
GATEWAY_INTERNAL_SECRET=MySecret123!