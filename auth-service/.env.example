APP_NAME="Infertility Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- DATABASE CONFIG ---
# Kết nối MySQL (XAMPP). Tạo database trước khi chạy migrate.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=infertility_management
DB_USERNAME=root
DB_PASSWORD=

# --- SESSION, CACHE & QUEUE ---
# Sử dụng Redis để tối ưu hiệu năng.
# Đảm bảo Redis Server đang chạy và PHP đã cài extension phpredis.
SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis
MEMCACHED_HOST=127.0.0.1

# --- REDIS CONFIG ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- JWT CONFIG ---
#'php artisan jwt:secret'
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=60

# --- CORS CONFIG ---
# URL của Frontend React
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- OTHER CONFIG ---
FILESYSTEM_DISK=local

# Mã kết nối api
GATEWAY_INTERNAL_SECRET=MySecret123!